<Window x:Class="TCC1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TCC1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Name="mainwindow">
    <Grid>
        <Button x:Name="AddUserBtn" CommandParameter="{x:Reference Name= mainwindow}" Command="{Binding ShowWindowCommand}" Height="30" Width="100" Content="Add User" HorizontalAlignment="Left" Margin="675,28,0,0" VerticalAlignment="Top"/>
        <ListView Name="UserList" Margin="25,70,25,70" ItemsSource="{Binding Users}">
            <ListView.View>
                <GridView>
                    <GridViewColumn DisplayMemberBinding="{Binding  Name}" Header="Name"/>
                    <GridViewColumn DisplayMemberBinding="{Binding Email}" Header="Email"/>
                </GridView>
            </ListView.View>
        </ListView>
        <TextBox x:Name="FilterTxt" TextChanged="FilterTxt_TextChanged"  Height="30" Width="200" HorizontalAlignment="Left" Margin="25,28,0,0" TextWrapping="Wrap" VerticalAlignment="Top"/>

    </Grid>
</Window>
